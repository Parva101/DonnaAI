APP_NAME=DonnaAI API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
DATABASE_URL=
SQL_ECHO=false
SESSION_SECRET_KEY=dev-session-secret-key-change-me-32
SESSION_COOKIE_NAME=donna_session
SESSION_EXPIRE_MINUTES=10080
SESSION_COOKIE_SECURE=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Google OAuth 2.0  (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Spotify OAuth 2.0  (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Groq (free — https://console.groq.com/keys)
GROQ_API_KEY=
