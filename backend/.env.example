APP_NAME=DonnaAI API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
DATABASE_URL=
SQL_ECHO=false
SESSION_SECRET_KEY=dev-session-secret-key-change-me-32
TOKEN_ENCRYPTION_KEY=
SESSION_COOKIE_NAME=donna_session
SESSION_EXPIRE_MINUTES=10080
SESSION_COOKIE_SECURE=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Google OAuth 2.0  (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8010/api/v1/auth/google/callback

# Spotify OAuth 2.0  (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8010/api/v1/auth/spotify/callback

# Slack OAuth 2.0 (https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8010/api/v1/auth/slack/callback
SLACK_SIGNING_SECRET=

# Microsoft / Teams OAuth 2.0 (https://portal.azure.com)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8010/api/v1/auth/teams/callback
TEAMS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Groq (free - https://console.groq.com/keys)
GROQ_API_KEY=
FALLBACK_GROQ_API_KEY=
FALLBACK_GROQ_API_KE_2=

# Gemini / Vertex API key
GOOGLE_API_KEY=

# News
NEWS_API_KEY=
NEWS_FETCH_INTERVAL_MINUTES=30

# Daily briefing / notifications
MORNING_BRIEFING_HOUR_UTC=13

# Voice providers (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp bridge
WHATSAPP_BRIDGE_RUNTIME_DIR=../whatsapp_bridge/runtime
WHATSAPP_BRIDGE_DEVICE_ID=donna-whatsapp-poc
